# 复制为 .env 并按本机调整。.env 不提交。
#
# 业务连接：受 RLS 约束的 app 角色（运行期用）
database_url=postgresql+asyncpg://app:app@localhost:5432/xborder
# 管理连接：超级用户（建库/角色/扩展/迁移用）。
# macOS Homebrew/Postgres.app 的超级用户通常是 OS 用户名，本地多为 trust 认证。
database_admin_url=postgresql+asyncpg://<superuser>@localhost:5432/xborder

# JWT（生产务必换成 >=32 字节随机串）
# jwt_secret=change-me

# LLM 网关（LiteLLM，OpenAI 兼容）
# litellm_base_url=http://localhost:4000
# litellm_master_key=change-me
