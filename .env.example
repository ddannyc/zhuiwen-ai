# 复制为 .env 并按本机调整。.env 不提交。
#
# 业务连接：受 RLS 约束的 app 角色（运行期用）
database_url=postgresql+asyncpg://app:app@localhost:5432/xborder
# 管理连接：超级用户（建库/角色/扩展/迁移用）。
# macOS Homebrew/Postgres.app 的超级用户通常是 OS 用户名，本地多为 trust 认证。
database_admin_url=postgresql+asyncpg://<superuser>@localhost:5432/xborder

# JWT（生产务必换成 >=32 字节随机串）
# jwt_secret=change-me

# CORS：前端允许源。生产把 CORS_ORIGINS 设为真实前端域名（CSV），并清空 CORS_ORIGIN_REGEX
# （私网正则仅开发便利，生产不放行局域网）。开发默认正则已覆盖 localhost + 私网 IP。
# CORS_ORIGINS=https://seller.example.com
# CORS_ORIGIN_REGEX=

# chat LLM —— gateway 用 LiteLLM SDK 进程内调用，打阿里百炼 (DashScope) 兼容端点。
# 国内区（中国大陆，百炼中国站 Key）。国际区改 dashscope-intl.aliyuncs.com（且需新加坡站 Key，不通用）。
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_API_KEY=<百炼中国站控制台 Key>
# chat_model=qwen-plus              # 默认模型

# embeddings（knowledge_base 域，本期未启用）走 OpenAI 兼容端点
LITELLM_MASTER_KEY=sk-local-dev
