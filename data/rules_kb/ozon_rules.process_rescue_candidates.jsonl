{"rule_id": "b66ec7f1-6e89-413e-b610-d53bff94056e", "platform": "ozon", "site": "GLOBAL", "original_language": "en", "rule_domain": "logistics_fulfillment", "product_category": [], "rule_type": "process", "title": "拒绝处置与产品移除", "summary": "卖家可在30天内拒绝处置并安排从FBP仓库移除损坏产品，逾期未响应则产品会被处置。", "content": "- 卖家有权拒绝处置并安排移除损坏产品\n- 移除须在收到通知后30天内完成\n- 若卖家未按时回应或移除产品，合作方将执行处置", "severity": "warning", "source_type": "official_help_center", "source_url": "https://global-help.ozon.com/en/fulfillment/fbp/supplies/fbp-utilization?region=CHN", "version": "2026.06.18-r1", "effective_date": null, "expiry_date": null, "last_verified_at": "2026-06-18", "verification_status": "needs_review", "confidence": "high", "related_rule_ids": [], "tags": ["拒绝处置", "移除", "30天"]}
{"rule_id": "5477778e-3c18-4f51-a04c-917a81fd5bc8", "platform": "ozon", "site": "GLOBAL", "original_language": "en", "rule_domain": "logistics_fulfillment", "product_category": [], "rule_type": "process", "title": "配送速度类型与最大配送时间", "summary": "系统定义了五种配送速度类型，每种有从仓库到莫斯科的最长配送时间上限，其中Economy类型根据货件分组进一步细分。", "content": "- Super Express：≤5天\n- Express：≤10天\n- Standard：≤15天\n- Economy：小型和高级小型组≤20天；超小型、平价、大型、高级大型组≤25天\n- Smart：根据商品重量和价格自动选择速度类型", "severity": "info", "source_type": "official_help_center", "source_url": "https://global-help.ozon.com/en/fulfillment/fbp/logistics/available-services?region=CHN", "version": "2026.06.18-r1", "effective_date": null, "expiry_date": null, "last_verified_at": "2026-06-18", "verification_status": "needs_review", "confidence": "high", "related_rule_ids": [], "tags": ["delivery speed", "FBP", "time limit", "Smart"]}
